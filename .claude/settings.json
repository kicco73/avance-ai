{
  "permissions": {
    "allow": [
      // pacchetti e dipendenze
      "Bash(.venv/bin/pip install *)",
      "Bash(npm install *)",
      "Bash(npm run *)",

      // python: copre py_compile, python -c, script, tutto — entro il venv del progetto
      "Bash(.venv/bin/python *)",

      // uvicorn su qualsiasi porta, non solo 8123/8124
      "Bash(.venv/bin/uvicorn main:app *)",

      // utility di debug/processo che usavi
      "Bash(jobs -l)",
      "Bash(kill %*)",
      "Bash(echo \"exit: $?\")",

      // pulizia scoped: solo dentro il progetto e /tmp, non ovunque
      "Bash(rm -rf /Users/enricocarniani/Documents/avance-prototype/**/__pycache__)",
      "Bash(rm -f /tmp/*.log)",
      "Bash(mkdir -p /Users/enricocarniani/Documents/avance-prototype/**)",

      // lettura file temporanei
      "Read(//tmp/**)",

      // scrittura/lettura del codice del progetto
      "Write(/Users/enricocarniani/Documents/avance-prototype/backend/**)",
      "Write(/Users/enricocarniani/Documents/avance-prototype/frontend/**)",
      "Edit(/Users/enricocarniani/Documents/avance-prototype/backend/**)",
      "Edit(/Users/enricocarniani/Documents/avance-prototype/frontend/**)",
      "Read"
    ],
    "deny": [
      "Read(**/.env)",
      "Write(**/.env)",
      "Edit(**/.env)"
    ],
    "additionalDirectories": [
      "/Users/enricocarniani/Documents/avance-prototype/backend",
      "/Users/enricocarniani/Documents/avance-prototype/frontend",
      "/private/tmp"
    ]
  }
}