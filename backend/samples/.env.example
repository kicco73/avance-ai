# Peewee connection URL (see backend/db.py). sqlite:///path.db for SQLite,
# mysql://user:pass@host/dbname for MySQL (requires adding a MySQL driver
# such as pymysql to requirements.txt — not included by default).

DATABASE_URL=sqlite:///avance.db

LLM_PROVIDER=gemini
LLM_API_KEY=
LLM_NAME=gemini-flash-lite-latest
